# OpenCode + oh-my-openagent Environment Variables
# Copy this file to ~/.bashrc or export these variables before running opencode

# Required: Moonshot AI (Kimi models)
export MOONSHOT_API_KEY=your_moonshot_key_here

# Required: Google Gemini
export GOOGLE_GENERATIVE_AI_API_KEY=your_google_key_here

# Required: Zhipu AI / Z.AI Coding Plan
export ZHIPU_API_KEY=your_zhipu_key_here

# Required: OpenCode Zen / OpenCode Go
export OPENCODE_API_KEY=your_opencode_key_here
