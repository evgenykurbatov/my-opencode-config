{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "default_agent": "gemini-primary",
  "autoupdate": false,
  "share": "disabled",
  "disabled_providers": [
    "github"
  ],
  "mcp": {
    "github": {
      "enabled": false
    }
  },
  "provider": {
    "google": {
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
              "video"
            ],
            "output": [
              "text"
            ]
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
              "video"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "agent": {
    "gemini-primary": {
      "description": "Main engineering and orchestration agent using Gemini 3.1 Pro",
      "mode": "primary",
      "model": "google/gemini-3.1-pro-preview",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": {
          "gemini-worker": "allow"
        }
      }
    },
    "gemini-worker": {
      "description": "Fast Gemini subagent for implementation and analysis",
      "mode": "subagent",
      "model": "google/gemini-2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true
}
